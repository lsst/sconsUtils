def copy_from_path_list(
    src_dirs,
    dest_dir: Path,
    log: logging.Logger,
    manifest: dict,
    prefix_root: Path,
    *,
    label: str,
    dry_run: bool,
    include_source: bool,
    on_conflict: str = "error",
):
    """Copy flat files from each source directory in ``src_dirs`` into ``dest_dir``.

    Only immediate children that are files or symlinks are copied
    (subdirectories are ignored).  Files matched by :func:`skip_file` are
    excluded unless ``include_source`` is True.

    Parameters
    ----------
    src_dirs : iterable[str | Path]
        Ordered list of source directories to scan.
    dest_dir : Path
        Destination flat directory (e.g. the bundle's ``lib/`` or ``bin/``).
    log : logging.Logger
        Logger for debug and progress messages.
    manifest : dict
        Manifest dict updated in-place via :func:`add_copied`.
    prefix_root : Path
        Root of the installation prefix, passed to :func:`add_copied`.
    label : str
        Short label used in debug messages (e.g. ``"lib"`` or ``"bin"``).
    dry_run : bool
        When True, log actions without copying.
    include_source : bool
        When True, source and build files are not excluded.
    on_conflict : {"error", "skip", "overwrite"}, optional
        Action when a destination file already exists.  Default ``"error"``.

    Raises
    ------
    TargetExistsError
        When ``on_conflict`` is ``"error"`` and a destination file already
        exists.
    """
    add_copied(manifest, dest_dir, prefix_root, was_dir=True)
    for src_dir in src_dirs:
        src = Path(src_dir)
        if not src.is_dir():
            log.debug("%s: skip non-dir %s", label, src)
            continue
        log.info("%s: scanning %s", label, src)
        for f in src.iterdir():
            if (f.is_file() or f.is_symlink()) and not skip_file(
                f, include_source=include_source
            ):
                dest = dest_dir / f.name
                copy_entry(
                    f,
                    dest,
                    log,
                    manifest,
                    prefix_root,
                    dry_run=dry_run,
                    on_conflict=on_conflict,
                )


def copy_pythonpath(
    src_dirs,
    python_dest: Path,
    log: logging.Logger,
    manifest: dict,
    prefix_root: Path,
    *,
    dry_run: bool,
    include_source: bool,
    on_conflict: str = "error",
):
    """Copy PYTHONPATH entries (packages and top-level modules) into ``python_dest``.

    Directories are copied recursively via :func:`copytree_record`; plain
    files are copied via :func:`copy_entry`.  Files matched by
    :func:`skip_file` are excluded unless ``include_source`` is True.

    Parameters
    ----------
    src_dirs : iterable[str | Path]
        Ordered list of directories from the ``PYTHONPATH`` env variable.
    python_dest : Path
        Destination Python directory (e.g. ``site-packages`` in a conda env).
    log : logging.Logger
        Logger for debug and progress messages.
    manifest : dict
        Manifest dict updated in-place via :func:`add_copied`.
    prefix_root : Path
        Root of the installation prefix, passed to :func:`add_copied`.
    dry_run : bool
        When True, log actions without copying.
    include_source : bool
        When True, source and build files are not excluded.
    on_conflict : {"error", "skip", "overwrite"}, optional
        Action when a destination path already exists.  Default ``"error"``.

    Raises
    ------
    TargetExistsError
        When ``on_conflict`` is ``"error"`` and a destination path already
        exists.
    """
    add_copied(manifest, python_dest, prefix_root, was_dir=True)
    ignore = make_ignore_patterns(include_source)

    for src_dir in src_dirs:
        src = Path(src_dir)
        if not src.is_dir():
            log.debug("python: skip non-dir %s", src)
            continue
        log.info("python: scanning %s", src)

        for f in src.iterdir():
            dest = python_dest / f.name
            if f.is_dir():
                copytree_record(
                    f,
                    dest,
                    log,
                    manifest,
                    prefix_root,
                    dry_run=dry_run,
                    ignore=ignore,
                    on_conflict=on_conflict,
                )
            else:
                if not skip_file(f, include_source=include_source):
                    copy_entry(
                        f,
                        dest,
                        log,
                        manifest,
                        prefix_root,
                        dry_run=dry_run,
                        on_conflict=on_conflict,
                    )


