def parse_args(argv=None):
    """Parse command-line arguments for the install / uninstall tool.

    Parameters
    ----------
    argv : list[str] or None, optional
        Argument list to parse.  When ``None``, ``sys.argv[1:]`` is used.

    Returns
    -------
    argparse.Namespace
        Parsed arguments with subcommand-specific attributes.
    """
    p = argparse.ArgumentParser(
        description="Install/uninstall a relocatable bundle (bin/lib/python) built from EUPS setup paths."
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    p_install = sub.add_parser(
        "install", help="Copy files and write a manifest (strict on existing targets)"
    )
    p_install.add_argument(
        "--prefix",
        help="Install root prefix. Layout: <prefix>/{bin,lib,python}. Mutually exclusive with --conda/--rootdir.",
    )
    p_install.add_argument(
        "--rootdir",
        help="Install into ROOTDIR/{bin,lib,python}. Mutually exclusive with --prefix/--conda.",
    )
    p_install.add_argument(
        "--conda",
        action="store_true",
        help="Install into the active (or inferred) conda env: <conda>/{bin,lib,site-packages}.",
    )
    p_install.add_argument(
        "--product",
        action="append",
        dest="products",
        default=[],
        help="Top-level EUPS product to include (repeatable). Default: lsst_distrib.",
    )
    p_install.add_argument(
        "--include-source",
        action="store_true",
        help="Include source/build files (disables the default filters/ignore patterns).",
    )
    p_install.add_argument(
        "--no-fix", action="store_true", help="Do not fix RPATH/install_name"
    )
    p_install.add_argument(
        "--force", action="store_true", help="If a manifest exists, uninstall first"
    )
    p_install.add_argument(
        "--on-conflict",
        choices=["error", "skip", "overwrite"],
        default="error",
        help="Action when a destination file/dir already exists: error (default), skip, or overwrite.",
    )
    p_install.add_argument(
        "--dry-run", action="store_true", help="Log actions without copying/writing"
    )

    p_dump = sub.add_parser(
        "dump-env",
        help="Print a bash script exporting non-PATH env vars from the active EUPS setup",
    )
    p_dump.add_argument(
        "--product",
        action="append",
        dest="products",
        default=[],
        help="Top-level EUPS product to include (repeatable). Default: lsst_distrib.",
    )
    p_dump.add_argument(
        "--output",
        "-o",
        help="Write the bash script to this file instead of stdout.",
    )

    p_uninstall = sub.add_parser(
        "uninstall", help="Remove files listed in the manifest"
    )
    p_uninstall.add_argument(
        "--prefix",
        required=True,
        help="Install root prefix (same root used during install; where the manifest lives).",
    )
    p_uninstall.add_argument(
        "--dry-run",
        action="store_true",
        help="Log what would be removed without removing",
    )

    p.add_argument(
        "-v",
        "--verbose",
        action="count",
        default=0,
        help="Increase verbosity (-v=INFO, -vv=DEBUG)",
    )
    return p.parse_args(argv)


def setup_logging(verbose: int, dry_run: bool = False):
    """Configure the root logger and return the named bundle logger.

    Parameters
    ----------
    verbose : int
        Verbosity count: 0 → WARNING, 1 → INFO, 2+ → DEBUG.
    dry_run : bool, optional
        When True, force level to at least INFO so dry-run output is always
        visible regardless of ``verbose``.

    Returns
    -------
    logging.Logger
        Logger named ``"bundle-eups"``.
    """
    level = logging.WARNING
    if verbose >= 2:
        level = logging.DEBUG
    elif verbose == 1 or dry_run:
        level = logging.INFO
    logging.basicConfig(level=level, format="%(levelname)s: %(message)s")
    return logging.getLogger("bundle-eups")


def do_install(args, log: logging.Logger) -> int:
    """Execute the ``install`` subcommand.

    Resolves install locations, optionally uninstalls a previous bundle,
    copies libraries / binaries / Python packages from active EUPS setup
    paths, patches binary RPATHs / install names, and writes the manifest.

    Parameters
    ----------
    args : argparse.Namespace
        Parsed CLI arguments from :func:`parse_args`.
    log : logging.Logger
        Logger for progress and error messages.

    Returns
    -------
    int
        0 on success, 2 on any error (conflict, missing tool, etc.).
    """
    products = args.products or ["lsst_distrib"]
    flavor = platform.system()
    selected = sum(x is not None for x in [args.prefix, args.rootdir]) + (
        1 if args.conda else 0
    )
    if selected > 1:
        log.error("Use only one of --prefix, --rootdir, or --conda")
        return 2

    prefix_arg = Path(args.prefix) if args.prefix else None
    rootdir_arg = Path(args.rootdir) if args.rootdir else None

    try:
        prefix_root, lib_dest, bin_dest, python_dest = resolve_install_locations(
            rootdir=rootdir_arg,
            conda=bool(args.conda),
            prefix=prefix_arg,
        )
    except RuntimeError as ex:
        log.error(str(ex))
        return 2
    mp = manifest_path(prefix_root)
    if mp.exists() and args.force:
        log.info("Existing manifest found; uninstalling first (--force)")
        rc = uninstall(prefix_root, log, dry_run=args.dry_run)
        if rc != 0:
            return rc
    elif mp.exists() and not args.force:
        log.error("Manifest already exists at %s (use --force or uninstall first)", mp)
        return 2

    if not args.dry_run:
        prefix_root.mkdir(parents=True, exist_ok=True)
        lib_dest.mkdir(parents=True, exist_ok=True)
        bin_dest.mkdir(parents=True, exist_ok=True)
        python_dest.mkdir(parents=True, exist_ok=True)

    e = eups.Eups()
    paths = build_paths_map(e, products, flavor, log)

    manifest = {
        "version": 1,
        "products": products,
        "include_source": bool(args.include_source),
        "layout": {
            "prefix_root": str(prefix_root),
            "bin": str(bin_dest),
            "lib": str(lib_dest),
            "python": str(python_dest),
            "mode": "conda"
            if args.conda
            else (
                "rootdir" if args.rootdir else ("prefix" if args.prefix else "default")
            ),
        },
        "files": [],
        "dirs": [],
    }

    try:
        lib_vars = {
            "LD_LIBRARY_PATH",
            "DYLD_LIBRARY_PATH",
        }
        libs = []
        for v in lib_vars:
            for p in paths.get(v, []):
                if p not in libs:
                    libs.append(p)
        copy_from_path_list(
            libs,
            lib_dest,
            log,
            manifest,
            prefix_root,
            label="lib",
            dry_run=args.dry_run,
            include_source=args.include_source,
            on_conflict=args.on_conflict,
        )

        copy_from_path_list(
            paths.get("PATH", []),
            bin_dest,
            log,
            manifest,
            prefix_root,
            label="bin",
            dry_run=args.dry_run,
            include_source=args.include_source,
            on_conflict=args.on_conflict,
        )

        copy_pythonpath(
            paths.get("PYTHONPATH", []),
            python_dest,
            log,
            manifest,
            prefix_root,
            dry_run=args.dry_run,
            include_source=args.include_source,
            on_conflict=args.on_conflict,
        )
    except TargetExistsError as ex:
        log.error(str(ex))
        save_manifest(prefix_root, manifest, dry_run=args.dry_run, log=log)
        return 2

    if not args.no_fix:
        try:

            def _to_abs(p: str) -> Path:
                pp = Path(p)
                return pp if pp.is_absolute() else (prefix_root / pp)

            fix_binary_paths(
                lib_dest,
                python_dest,
                bin_dest,
                log,
                dry_run=args.dry_run,
                installed_files=[_to_abs(f) for f in manifest["files"]],
            )
        except FileNotFoundError as ex:
            log.error("Required tool not found: %s", ex.filename)
            save_manifest(prefix_root, manifest, dry_run=args.dry_run, log=log)
            return 2
        except subprocess.CalledProcessError as ex:
            log.error("Binary patch tool failed: %s", ex)
            save_manifest(prefix_root, manifest, dry_run=args.dry_run, log=log)
            return 2

    manifest["files"] = sorted(set(manifest["files"]))
    manifest["dirs"] = sorted(set(manifest["dirs"]), key=len, reverse=True)
    save_manifest(prefix_root, manifest, dry_run=args.dry_run, log=log)

    if not args.dry_run:
        print("\n" + "=" * 60)
        print("Installed bundle.")
        print(f"  root:   {prefix_root}")
        print(f"  bin:    {bin_dest}")
        print(f"  lib:    {lib_dest}")
        print(f"  python: {python_dest}")
        print(
            f"\nUninstall with:\n  {Path(__file__).name} uninstall --prefix {prefix_root}"
        )
        print("=" * 60)

    return 0


def do_dump_env(args, log: logging.Logger) -> int:
    """Execute the ``dump-env`` subcommand.

    Collects non-path environment variables from the active EUPS setup and
    writes a bash script of ``export VAR=value`` lines.

    Parameters
    ----------
    args : argparse.Namespace
        Parsed CLI arguments.
    log : logging.Logger
        Logger for progress messages.

    Returns
    -------
    int
        0 on success.
    """
    products = args.products or ["lsst_distrib"]
    flavor = platform.system()

    e = eups.Eups()
    env_vars = build_non_path_env(e, products, flavor, log)

    lines = [
        "#!/usr/bin/env bash",
        "# Auto-generated: non-PATH environment variables from EUPS setup",
        "",
    ]
    for var, value in sorted(env_vars.items()):
        escaped = value.replace("'", "'\\''")
        lines.append(f"export {var}='{escaped}'")
    lines.append("")

    output = "\n".join(lines)
    if args.output:
        Path(args.output).write_text(output)
        log.info("Written to %s", args.output)
    else:
        print(output, end="")

    return 0


def main(argv=None):
    """Entry point: parse arguments, dispatch to install or uninstall.

    Parameters
    ----------
    argv : list[str] or None, optional
        Argument list.  When ``None``, ``sys.argv[1:]`` is used.

    Returns
    -------
    int
        Exit code (0 success, 2 error).
    """
    args = parse_args(argv)
    log = setup_logging(args.verbose, dry_run=getattr(args, "dry_run", False))

    if args.cmd == "uninstall":
        return uninstall(Path(args.prefix), log, dry_run=args.dry_run)
    if args.cmd == "install":
        return do_install(args, log)
    if args.cmd == "dump-env":
        return do_dump_env(args, log)

    log.error("Unknown command")
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
